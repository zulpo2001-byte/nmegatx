<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NME SaaS — 控制台</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;700&family=Syne:wght@700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#060d1a;
  --panel:#0a1628;
  --panel2:#0e1d35;
  --panel3:#132240;
  --border:#1a2d4a;
  --border2:#243d60;
  --text:#e2eaf7;
  --text2:#9bb0cc;
  --text3:#566b8a;
  --brand:#3b82f6;
  --brand2:#2563eb;
  --brand-glow:rgba(59,130,246,.25);
  --stripe:#635bff;
  --stripe-glow:rgba(99,91,255,.2);
  --paypal:#009cde;
  --paypal-glow:rgba(0,156,222,.18);
  --green:#10b981;
  --red:#ef4444;
  --amber:#f59e0b;
  --purple:#8b5cf6;
  --mono:'JetBrains Mono',monospace;
  --head:'Syne',sans-serif;
  --body:'DM Sans',sans-serif;
}
body{min-height:100vh;background:var(--bg);font-family:var(--body);color:var(--text);overflow-x:hidden}
body::before{content:'';position:fixed;inset:0;background:
  radial-gradient(ellipse 80% 60% at 10% -10%,rgba(59,130,246,.07) 0%,transparent 60%),
  radial-gradient(ellipse 60% 50% at 90% 100%,rgba(99,102,241,.06) 0%,transparent 60%);
  pointer-events:none;z-index:0}

/* ── Layout ── */
.app{display:flex;min-height:100vh;position:relative;z-index:1}
.sidebar{width:260px;background:rgba(10,22,40,.97);border-right:1px solid var(--border);padding:0;position:sticky;top:0;height:100vh;overflow-y:auto;overflow-x:hidden;flex-shrink:0;display:flex;flex-direction:column}
.main{flex:1;display:flex;flex-direction:column;min-width:0}

/* ── Sidebar ── */
.brand{padding:20px 18px 14px;border-bottom:1px solid var(--border)}
.brand-inner{display:flex;align-items:center;gap:10px}
.brand-icon{width:34px;height:34px;background:linear-gradient(135deg,var(--brand),var(--stripe));border-radius:10px;display:flex;align-items:center;justify-content:center;font-family:var(--head);font-weight:800;font-size:14px;color:#fff;flex-shrink:0;box-shadow:0 4px 12px rgba(59,130,246,.35)}
.brand-text h1{font-family:var(--head);font-size:17px;font-weight:800;letter-spacing:-.3px;line-height:1}
.brand-text p{font-size:10.5px;color:var(--text3);margin-top:3px;font-family:var(--mono)}
.nav-section{padding:10px 10px 0}
.nav-section-title{font-size:10px;font-weight:700;color:var(--text3);letter-spacing:.12em;text-transform:uppercase;padding:0 8px 7px}
.nav-item{display:flex;align-items:center;gap:9px;padding:8px 10px;border-radius:9px;cursor:pointer;color:var(--text2);font-size:13px;font-weight:500;transition:.12s;border:1px solid transparent;margin-bottom:1px;white-space:nowrap}
.nav-item:hover{background:rgba(59,130,246,.1);border-color:rgba(59,130,246,.15);color:var(--text)}
.nav-item.active{background:rgba(59,130,246,.16);border-color:rgba(59,130,246,.3);color:#93c5fd}
.nav-item .ico{width:18px;text-align:center;font-size:14px;flex-shrink:0}
.sidebar-foot{margin-top:auto;padding:12px 14px;border-top:1px solid var(--border);font-size:11px;color:var(--text3);font-family:var(--mono)}

/* ── Topbar ── */
.topbar{display:flex;align-items:center;justify-content:space-between;padding:10px 22px;border-bottom:1px solid var(--border);background:rgba(6,13,26,.92);backdrop-filter:blur(12px);position:sticky;top:0;z-index:50}
.who{display:flex;align-items:center;gap:10px}
.avatar{width:32px;height:32px;border-radius:9px;background:rgba(59,130,246,.2);border:1px solid rgba(59,130,246,.35);display:flex;align-items:center;justify-content:center;font-family:var(--head);font-weight:800;font-size:13px;color:var(--brand)}
.who-info .name{font-size:13px;font-weight:600}
.who-info .role{font-size:10.5px;color:var(--text3);font-family:var(--mono)}
.topbar-actions{display:flex;gap:7px}
.btn-sm{background:transparent;border:1px solid var(--border2);color:var(--text2);padding:6px 13px;border-radius:7px;cursor:pointer;font-size:12.5px;font-family:var(--body);font-weight:500;transition:.12s}
.btn-sm:hover{border-color:var(--brand);color:var(--text)}

/* ── Content ── */
.content{padding:22px;flex:1}
.page-header{margin-bottom:18px}
.page-header h2{font-family:var(--head);font-size:21px;font-weight:800;letter-spacing:-.4px}
.page-header p{color:var(--text2);font-size:12.5px;margin-top:4px}

/* ── Cards ── */
.card{background:var(--panel);border:1px solid var(--border);border-radius:14px;padding:20px}
.card+.card{margin-top:14px}
.card-title{font-family:var(--head);font-size:14px;font-weight:700;margin-bottom:14px;display:flex;align-items:center;justify-content:space-between;gap:10px}

/* ── Stats grid ── */
.stats-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:12px;margin-bottom:18px}
.stat-card{background:var(--panel);border:1px solid var(--border);border-radius:12px;padding:15px}
.stat-label{font-size:11px;color:var(--text3);font-weight:700;text-transform:uppercase;letter-spacing:.08em}
.stat-val{font-family:var(--head);font-size:26px;font-weight:800;margin-top:5px}
.stat-sub{font-size:11px;color:var(--text3);margin-top:2px}

/* ── Table ── */
.tbl-wrap{overflow-x:auto;margin:-2px}
table{width:100%;border-collapse:collapse;font-size:12.5px}
th{font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--text3);padding:8px 12px;border-bottom:1px solid var(--border);text-align:left;white-space:nowrap}
td{padding:9px 12px;border-bottom:1px solid rgba(26,45,74,.5);vertical-align:middle}
tr:last-child td{border-bottom:none}
tr:hover td{background:rgba(59,130,246,.04)}
.mono{font-family:var(--mono);font-size:11px;color:var(--text2)}

/* ── Badges ── */
.badge{display:inline-flex;align-items:center;gap:3px;padding:2px 7px;border-radius:5px;font-size:10.5px;font-weight:600;white-space:nowrap}
.badge-green{background:rgba(16,185,129,.15);color:#34d399;border:1px solid rgba(16,185,129,.25)}
.badge-red{background:rgba(239,68,68,.12);color:#f87171;border:1px solid rgba(239,68,68,.2)}
.badge-amber{background:rgba(245,158,11,.12);color:#fbbf24;border:1px solid rgba(245,158,11,.2)}
.badge-blue{background:rgba(59,130,246,.13);color:#60a5fa;border:1px solid rgba(59,130,246,.22)}
.badge-stripe{background:rgba(99,91,255,.15);color:#a5b4fc;border:1px solid rgba(99,91,255,.25)}
.badge-paypal{background:rgba(0,156,222,.12);color:#67e8f9;border:1px solid rgba(0,156,222,.2)}
.badge-gray{background:rgba(86,107,138,.15);color:var(--text3);border:1px solid rgba(86,107,138,.2)}
.badge-sand{background:rgba(26,45,74,.6);color:var(--text2);border:1px solid var(--border)}
.badge-purple{background:rgba(139,92,246,.13);color:#c4b5fd;border:1px solid rgba(139,92,246,.25)}

/* ── Forms ── */
.form-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(210px,1fr));gap:11px;margin-bottom:13px}
.form-group{display:flex;flex-direction:column;gap:5px}
.form-group label{font-size:11px;font-weight:600;color:var(--text2);letter-spacing:.03em}
.form-group input,.form-group select,.form-group textarea{background:rgba(6,13,26,.8);border:1px solid var(--border2);border-radius:8px;padding:8px 11px;color:var(--text);font-size:12.5px;font-family:var(--body);outline:none;transition:.12s;width:100%}
.form-group input:focus,.form-group select:focus,.form-group textarea:focus{border-color:var(--brand);box-shadow:0 0 0 3px var(--brand-glow)}
.form-group select option{background:#0a1628}

/* ── Buttons ── */
.btn-primary{background:var(--brand);color:#fff;border:none;border-radius:8px;padding:8px 16px;font-size:13px;font-weight:600;cursor:pointer;font-family:var(--body);transition:.12s;display:inline-flex;align-items:center;gap:6px}
.btn-primary:hover{background:var(--brand2);box-shadow:0 4px 14px rgba(59,130,246,.35)}
.btn-stripe{background:rgba(99,91,255,.15);color:#a5b4fc;border:1px solid rgba(99,91,255,.3);border-radius:8px;padding:8px 16px;font-size:13px;font-weight:600;cursor:pointer;font-family:var(--body);transition:.12s;display:inline-flex;align-items:center;gap:6px}
.btn-stripe:hover{background:rgba(99,91,255,.25)}
.btn-paypal{background:rgba(0,156,222,.12);color:#67e8f9;border:1px solid rgba(0,156,222,.25);border-radius:8px;padding:8px 16px;font-size:13px;font-weight:600;cursor:pointer;font-family:var(--body);transition:.12s;display:inline-flex;align-items:center;gap:6px}
.btn-paypal:hover{background:rgba(0,156,222,.22)}
.btn-danger{background:rgba(239,68,68,.1);color:#f87171;border:1px solid rgba(239,68,68,.2);border-radius:7px;padding:5px 11px;font-size:11.5px;cursor:pointer;font-family:var(--body);transition:.12s}
.btn-danger:hover{background:rgba(239,68,68,.2)}
.btn-ghost{background:transparent;color:var(--text2);border:1px solid var(--border2);border-radius:7px;padding:5px 11px;font-size:11.5px;cursor:pointer;font-family:var(--body);transition:.12s}
.btn-ghost:hover{border-color:var(--brand);color:var(--text)}
.btn-icon{background:transparent;border:1px solid var(--border);border-radius:6px;padding:4px 8px;cursor:pointer;font-size:12px;color:var(--text3);transition:.12s}
.btn-icon:hover{border-color:var(--border2);color:var(--text)}

/* ── Toggle ── */
.toggle{position:relative;display:inline-block;width:36px;height:20px;cursor:pointer;flex-shrink:0}
.toggle input{opacity:0;width:0;height:0}
.toggle-track{position:absolute;inset:0;background:var(--border2);border-radius:20px;transition:.2s}
.toggle input:checked~.toggle-track{background:var(--brand)}
.toggle-thumb{position:absolute;left:3px;top:3px;width:14px;height:14px;background:#fff;border-radius:50%;transition:.2s;box-shadow:0 1px 4px rgba(0,0,0,.3)}
.toggle input:checked~.toggle-thumb{left:19px}

/* ── Strategy cards ── */
.strategy-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:11px;margin-bottom:16px}
.strategy-card{border:2px solid var(--border);border-radius:12px;padding:15px;cursor:pointer;transition:.15s;background:var(--panel2)}
.strategy-card.active{border-color:var(--brand);background:rgba(59,130,246,.08)}
.strategy-card:hover:not(.active){border-color:var(--border2)}
.strategy-card h4{font-family:var(--head);font-size:13px;font-weight:700;margin-bottom:5px}
.strategy-card p{font-size:11.5px;color:var(--text2);line-height:1.5}
.strategy-icon{font-size:20px;margin-bottom:7px}

/* ── Account cards (Stripe/PayPal) ── */
.account-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:14px}
.account-card{border-radius:13px;padding:17px;position:relative;transition:.15s;border:1px solid var(--border)}
.account-card.stripe-card{background:linear-gradient(135deg,rgba(99,91,255,.08) 0%,var(--panel2) 100%);border-color:rgba(99,91,255,.2)}
.account-card.stripe-card:hover{border-color:rgba(99,91,255,.4)}
.account-card.paypal-card{background:linear-gradient(135deg,rgba(0,156,222,.08) 0%,var(--panel2) 100%);border-color:rgba(0,156,222,.18)}
.account-card.paypal-card:hover{border-color:rgba(0,156,222,.35)}
.account-card.disabled{opacity:.55}
.account-card-header{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:11px}
.account-card-label{font-weight:700;font-size:14px;line-height:1.2}
.account-card-sub{font-family:var(--mono);font-size:10.5px;color:var(--text3);margin-top:3px}
.account-card-stats{display:grid;grid-template-columns:1fr 1fr 1fr;gap:7px;margin:11px 0}
.account-stat{background:rgba(6,13,26,.5);border:1px solid var(--border);border-radius:8px;padding:7px 9px;text-align:center}
.account-stat-label{font-size:9.5px;color:var(--text3);font-weight:700;text-transform:uppercase}
.account-stat-val{font-family:var(--head);font-size:16px;font-weight:800;margin-top:2px}
.account-card-actions{display:flex;gap:6px;margin-top:11px;padding-top:11px;border-top:1px solid var(--border)}
.weight-bar-wrap{margin:8px 0 4px}
.weight-bar-label{display:flex;justify-content:space-between;font-size:10.5px;color:var(--text3);margin-bottom:5px}
.weight-bar{height:5px;background:var(--border);border-radius:3px;overflow:hidden}
.weight-bar-fill{height:100%;border-radius:3px;transition:.4s}
.weight-bar-fill.stripe-fill{background:linear-gradient(90deg,var(--stripe),#8b5cf6)}
.weight-bar-fill.paypal-fill{background:linear-gradient(90deg,var(--paypal),#06b6d4)}

/* ── Product cards ── */
.product-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(270px,1fr));gap:13px}
.product-card{background:var(--panel2);border:1px solid var(--border);border-radius:12px;padding:15px;position:relative;transition:.15s}
.product-card:hover{border-color:var(--border2)}
.product-card.disabled{opacity:.55}
.product-card-header{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:11px}
.product-card-label{font-weight:700;font-size:13.5px}
.product-card-id{font-family:var(--mono);font-size:10.5px;color:var(--text3);margin-top:2px}
.product-card-meta{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:11px}
.product-card-stats{display:grid;grid-template-columns:1fr 1fr;gap:7px}
.product-stat{background:var(--panel);border:1px solid var(--border);border-radius:7px;padding:7px 9px}
.product-stat-label{font-size:9.5px;color:var(--text3);font-weight:700;text-transform:uppercase}
.product-stat-val{font-family:var(--head);font-size:17px;font-weight:800;margin-top:2px}
.product-card-actions{display:flex;gap:5px;margin-top:11px;padding-top:11px;border-top:1px solid var(--border)}

/* ── Smart Routing ── */
.routing-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:13px}
.routing-card{background:var(--panel2);border:1px solid var(--border);border-radius:12px;padding:16px;transition:.15s}
.routing-card:hover{border-color:var(--border2)}
.routing-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
.routing-score{font-family:var(--head);font-size:28px;font-weight:800}
.metric-row{display:flex;justify-content:space-between;align-items:center;padding:5px 0;border-bottom:1px solid rgba(26,45,74,.4);font-size:12px}
.metric-row:last-child{border-bottom:none}
.metric-label{color:var(--text3);font-size:11px}
.metric-val{font-family:var(--mono);font-size:11.5px;font-weight:600}
.score-ring{position:relative;width:52px;height:52px;flex-shrink:0}
.score-ring svg{transform:rotate(-90deg)}
.score-ring .score-text{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-family:var(--head);font-size:12px;font-weight:800}

/* ── Channel metrics chart ── */
.metrics-row{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:12px;margin-bottom:16px}
.metric-card{background:var(--panel);border:1px solid var(--border);border-radius:10px;padding:14px}
.metric-card-label{font-size:10.5px;color:var(--text3);font-weight:700;text-transform:uppercase;letter-spacing:.06em}
.metric-card-val{font-family:var(--head);font-size:24px;font-weight:800;margin:5px 0 2px}
.metric-card-sub{font-size:11px;color:var(--text3)}
.mini-chart{display:flex;align-items:flex-end;gap:3px;height:32px;margin-top:8px}
.mini-bar{flex:1;border-radius:2px 2px 0 0;min-height:3px;transition:.3s}

/* ── Key display ── */
.key-box{background:rgba(6,13,26,.8);border:1px solid var(--border2);border-radius:8px;padding:9px 13px;font-family:var(--mono);font-size:11.5px;word-break:break-all;position:relative;margin-top:7px;color:#93c5fd}
.key-copy{position:absolute;right:7px;top:7px;background:var(--panel2);border:1px solid var(--border);border-radius:5px;padding:2px 7px;font-size:10.5px;cursor:pointer;color:var(--text2);font-family:var(--body)}
.key-copy:hover{color:var(--text)}
.config-string-box{background:rgba(6,13,26,.9);border:1px solid var(--brand);border-radius:10px;padding:13px;font-family:var(--mono);font-size:10.5px;word-break:break-all;color:#93c5fd;position:relative;margin-top:11px}
.config-hint{font-size:11.5px;color:var(--amber);margin-top:7px;padding:7px 11px;background:rgba(245,158,11,.08);border:1px solid rgba(245,158,11,.2);border-radius:7px}

/* ── Modal ── */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.7);backdrop-filter:blur(5px);z-index:200;display:none;align-items:center;justify-content:center}
.modal-overlay.open{display:flex}
.modal{background:var(--panel);border:1px solid var(--border2);border-radius:15px;padding:22px;width:520px;max-width:92vw;max-height:88vh;overflow-y:auto;position:relative}
.modal-title{font-family:var(--head);font-size:17px;font-weight:800;margin-bottom:16px;display:flex;align-items:center;justify-content:space-between}
.modal-close{background:transparent;border:none;color:var(--text3);font-size:20px;cursor:pointer;line-height:1;padding:0 4px}
.modal-close:hover{color:var(--text)}
.modal-actions{display:flex;justify-content:flex-end;gap:9px;margin-top:18px;padding-top:14px;border-top:1px solid var(--border)}

/* ── Tabs ── */
.tabs{display:flex;gap:4px;margin-bottom:16px;background:var(--panel2);border-radius:10px;padding:4px;border:1px solid var(--border)}
.tab{flex:1;text-align:center;padding:7px 12px;border-radius:7px;cursor:pointer;font-size:12.5px;font-weight:600;color:var(--text3);transition:.12s}
.tab.active{background:var(--panel);color:var(--text);box-shadow:0 1px 4px rgba(0,0,0,.3)}
.tab:hover:not(.active){color:var(--text2)}

/* ── Util ── */
.spinner{width:15px;height:15px;border:2px solid rgba(255,255,255,.15);border-top-color:var(--brand);border-radius:50%;animation:spin .7s linear infinite;display:inline-block;vertical-align:middle}
@keyframes spin{to{transform:rotate(360deg)}}
.loading{display:flex;align-items:center;gap:10px;color:var(--text3);padding:32px 0}
.empty{text-align:center;padding:36px;color:var(--text3)}
.empty-icon{font-size:30px;margin-bottom:8px}
.err{background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.2);color:#fca5a5;border-radius:8px;padding:9px 13px;font-size:12.5px;margin-bottom:11px;display:none}
.divider{height:1px;background:var(--border);margin:14px 0}
.flex-between{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px}
.flex-gap{display:flex;align-items:center;gap:7px;flex-wrap:wrap}
pre.json{white-space:pre-wrap;word-break:break-word;font-family:var(--mono);font-size:11px;color:#93c5fd;background:rgba(6,13,26,.6);border:1px solid var(--border);border-radius:8px;padding:13px;margin-top:7px}
.section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;padding-bottom:12px;border-bottom:1px solid var(--border)}
.section-header h3{font-family:var(--head);font-size:15px;font-weight:700}
.info-box{background:var(--panel2);border:1px solid var(--border);border-radius:9px;padding:11px 13px;font-size:12px;color:var(--text2);line-height:1.6;margin-bottom:13px}
.info-box strong{color:var(--text)}
.highlight-stripe{color:var(--stripe)}
.highlight-paypal{color:var(--paypal)}
</style>
</head>
<body>
<div class="app">
  <aside class="sidebar">
    <div class="brand">
      <div class="brand-inner">
        <div class="brand-icon">N</div>
        <div class="brand-text">
          <h1>NME <span style="color:var(--brand)">SaaS</span></h1>
          <p>payment gateway v9</p>
        </div>
      </div>
    </div>
    <div id="sidebarMenu"></div>
    <div class="sidebar-foot" id="sidebarFoot">loading…</div>
  </aside>

  <div class="main">
    <div class="topbar">
      <div class="who">
        <div class="avatar" id="topAvatar">?</div>
        <div class="who-info">
          <div class="name" id="topName">—</div>
          <div class="role" id="topRole">—</div>
        </div>
      </div>
      <div class="topbar-actions">
        <button class="btn-sm" id="btnRefresh">↻ 刷新</button>
        <button class="btn-sm" id="btnLogout">退出登录</button>
      </div>
    </div>
    <div class="content" id="pageContent">
      <div class="loading"><span class="spinner"></span> 加载中…</div>
    </div>
  </div>
</div>

<!-- Modal -->
<div class="modal-overlay" id="modalOverlay">
  <div class="modal" id="modalBox">
    <div class="modal-title">
      <span id="modalTitle">操作</span>
      <button class="modal-close" onclick="closeModal()">✕</button>
    </div>
    <div id="modalBody"></div>
  </div>
</div>

<script>
'use strict';

/* ══════════════════════════════════════════
   State & Auth
══════════════════════════════════════════ */
const S = {
  token: localStorage.getItem('nme_token') || '',
  user: null, role: '', perms: {},
  currentPage: '',
};

function can(p){ return true; } // 默认全部权限开放
function roleLabel(r){ return {super_admin:'超级管理员',user:'用户'}[r]||r||'—'; }

async function api(method, path, body=null){
  const opts={method,headers:{'Accept':'application/json','Content-Type':'application/json'}};
  if(S.token) opts.headers['Authorization']='Bearer '+S.token;
  if(body) opts.body=JSON.stringify(body);
  const res=await fetch('/api'+path, opts);
  if(res.status===401){ doLogout(); return null; }
  const d=await res.json().catch(()=>({}));
  if(!res.ok||d.ok===false) throw new Error(d.message||`HTTP ${res.status}`);
  return d.data??d;
}
const GET=(p)=>api('GET',p);
const POST=(p,b)=>api('POST',p,b);
const PUT=(p,b)=>api('PUT',p,b);
const DEL=(p)=>api('DELETE',p);

/* ══════════════════════════════════════════
   UI Helpers
══════════════════════════════════════════ */
function html(s){ return String(s).replace(/[&<>"']/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m])); }
function setContent(h){ document.getElementById('pageContent').innerHTML=h; }
function loading(){ setContent('<div class="loading"><span class="spinner"></span> 加载中…</div>'); }
function empty(icon,msg){ return `<div class="empty"><div class="empty-icon">${icon}</div><p>${msg}</p></div>`; }

function badgeStatus(s){
  const map={pending:'badge-amber',completed:'badge-green',failed:'badge-red',abandoned:'badge-gray'};
  return `<span class="badge ${map[s]||'badge-gray'}">${s}</span>`;
}
function badgePM(pm){
  if(pm==='stripe') return `<span class="badge badge-stripe">💳 Stripe</span>`;
  if(pm==='paypal') return `<span class="badge badge-paypal">🅿 PayPal</span>`;
  return `<span class="badge badge-blue">${pm||'—'}</span>`;
}
function badgeSandbox(sb){ return sb?`<span class="badge badge-amber">沙盒</span>`:`<span class="badge badge-green">生产</span>`; }
function fmtDate(d){ if(!d)return'—'; return new Date(d).toLocaleString('zh-CN',{hour12:false}); }
function fmtAgo(d){ if(!d)return'从未'; const s=Math.floor((Date.now()-new Date(d))/1000); if(s<60)return s+'秒前'; if(s<3600)return Math.floor(s/60)+'分钟前'; if(s<86400)return Math.floor(s/3600)+'小时前'; return Math.floor(s/86400)+'天前'; }
function fmtMoney(v){ return v!=null?'$'+Number(v).toFixed(2):'—'; }

function copyText(text){
  navigator.clipboard.writeText(text).then(()=>showToast('已复制到剪贴板')).catch(()=>{
    const el=document.createElement('textarea');
    el.value=text;el.style.cssText='position:fixed;opacity:0';
    document.body.appendChild(el);el.select();document.execCommand('copy');
    document.body.removeChild(el);showToast('已复制');
  });
}

function showToast(msg, err=false){
  const t=document.createElement('div');
  t.style.cssText=`position:fixed;bottom:22px;right:22px;z-index:999;padding:9px 16px;border-radius:9px;font-size:12.5px;font-weight:600;transition:.3s;pointer-events:none;${
    err?'background:rgba(239,68,68,.15);border:1px solid rgba(239,68,68,.3);color:#f87171'
      :'background:rgba(16,185,129,.15);border:1px solid rgba(16,185,129,.3);color:#6ee7b7'}`;
  t.textContent=msg;document.body.appendChild(t);
  setTimeout(()=>{t.style.opacity='0';setTimeout(()=>t.remove(),300)},2200);
}

function openModal(title,bodyHTML){
  document.getElementById('modalTitle').textContent=title;
  document.getElementById('modalBody').innerHTML=bodyHTML;
  document.getElementById('modalOverlay').classList.add('open');
}
function closeModal(){ document.getElementById('modalOverlay').classList.remove('open'); }
document.getElementById('modalOverlay').addEventListener('click',e=>{if(e.target===e.currentTarget)closeModal();});

/* ══════════════════════════════════════════
   Sidebar / Navigation
══════════════════════════════════════════ */
const MENU=[
  {section:'概览',items:[
    {id:'overview',label:'控制台概览',icon:'⊞'},
  ]},
  {section:'支付通道',roles:['user','super_admin'],items:[
    {id:'products',    label:'B站产品管理',     icon:'📦'},
    {id:'stripe',      label:'Stripe 账号',     icon:'💳'},
    {id:'paypal',      label:'PayPal 账号',     icon:'🅿'},
    {id:'multichannel',label:'多渠道负载均衡',  icon:'⚖'},
    {id:'strategy',    label:'轮询策略配置',    icon:'🔄'},
    {id:'webhooks',    label:'A/B 站端点',      icon:'🔗'},
  ]},
  {section:'账户管理',roles:['user','super_admin'],items:[
    {id:'orders',  label:'我的订单', icon:'📋'},
    {id:'apikeys', label:'API Key',  icon:'🔑'},
  ]},
  {section:'管理后台',roles:['super_admin'],items:[
    {id:'admin-stats',    label:'系统统计',   icon:'📈'},
    {id:'admin-users',    label:'用户管理',   icon:'👥'},
    {id:'admin-orders',   label:'全部订单',   icon:'🧾'},
    {id:'admin-routing',  label:'智能路由分析',icon:'🧠'},
    {id:'admin-risk',     label:'风控规则',   icon:'🛡'},
    {id:'admin-alerts',   label:'告警中心',   icon:'🚨'},
    {id:'admin-settings', label:'系统设置',   icon:'⚙'},
    {id:'admin-audit',    label:'审计日志',   icon:'📝'},
    {id:'admin-reports',  label:'数据报表',   icon:'📊'},
  ]},
];

function buildSidebar(){
  const wrap=document.getElementById('sidebarMenu');
  wrap.innerHTML='';
  MENU.forEach(sec=>{
    if(sec.roles&&!sec.roles.includes(S.role)) return;
    const div=document.createElement('div');
    div.className='nav-section';
    div.innerHTML=`<div class="nav-section-title">${sec.section}</div>`;
    sec.items.forEach(it=>{
      const el=document.createElement('div');
      el.className='nav-item';el.dataset.page=it.id;
      el.innerHTML=`<span class="ico">${it.icon}</span><span>${it.label}</span>`;
      el.onclick=()=>navigate(it.id);
      div.appendChild(el);
    });
    wrap.appendChild(div);
  });
}

async function navigate(id){
  S.currentPage=id;
  document.querySelectorAll('.nav-item').forEach(x=>x.classList.toggle('active',x.dataset.page===id));
  loading();
  const fn=Pages[id];
  try{ await (fn?fn():setContent('<div class="card"><div class="empty">页面未找到</div></div>')); }
  catch(e){ setContent(`<div class="card"><div class="err" style="display:block">❌ ${html(e.message||'加载失败')}</div></div>`); }
}

/* ══════════════════════════════════════════
   Page: Overview
══════════════════════════════════════════ */
async function pageOverview(){
  let dash={};
  try{ dash=await GET('/user/dashboard'); }catch(e){}
  setContent(`
    <div class="page-header"><h2>控制台概览</h2><p>欢迎回来，${html(S.user?.email||'')}</p></div>
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-label">总订单</div>
        <div class="stat-val" style="color:var(--brand)">${dash.orders_total??'—'}</div>
        <div class="stat-sub">累计</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">待支付</div>
        <div class="stat-val" style="color:var(--amber)">${dash.pending??'—'}</div>
        <div class="stat-sub">pending</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">已完成</div>
        <div class="stat-val" style="color:var(--green)">${dash.completed??'—'}</div>
        <div class="stat-sub">completed</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">成功率</div>
        <div class="stat-val" style="color:var(--text)">${dash.success_rate!=null?(+dash.success_rate).toFixed(1)+'%':'—'}</div>
        <div class="stat-sub">completed / total</div>
      </div>
    </div>
    <div class="card">
      <div class="card-title">账户信息</div>
      <table><thead><tr><th>字段</th><th>值</th></tr></thead><tbody>
        <tr><td>邮箱</td><td>${html(S.user?.email||'—')}</td></tr>
        <tr><td>角色</td><td><span class="badge badge-blue">${roleLabel(S.role)}</span></td></tr>
        <tr><td>负载策略</td><td><span class="badge badge-sand">${html(S.user?.product_strategy||'round_robin')}</span></td></tr>
      </tbody></table>
    </div>
  `);
}

/* ══════════════════════════════════════════
   Page: B站产品管理
══════════════════════════════════════════ */
async function pageProducts(){
  const data=await GET('/user/products');
  const items=data?.items||[];
  setContent(`
    <div class="page-header flex-between">
      <div><h2>B站产品管理</h2><p>管理 B 站 WooCommerce 产品，输入产品 ID 即可加入轮询</p></div>
      <div class="flex-gap">
        <button class="btn-ghost" onclick="openQuickAddProduct()">⚡ 快速添加</button>
        <button class="btn-primary" onclick="openAddProduct()">＋ 完整添加</button>
      </div>
    </div>
    ${items.length===0?`<div class="card">${empty('📦','暂无产品，点击右上角快速添加')}</div>`:''}
    <div class="product-grid" id="productGrid">${items.map(renderProductCard).join('')}</div>
  `);
}

function renderProductCard(p){
  return `
  <div class="product-card ${p.enabled?'':'disabled'}" id="pc-${p.id}">
    <div class="product-card-header">
      <div>
        <div class="product-card-label">${html(p.label||p.b_product_id)}</div>
        <div class="product-card-id">${html(p.b_product_id)}</div>
      </div>
      <label class="toggle" onclick="toggleProduct(${p.id},${p.enabled})">
        <input type="checkbox" ${p.enabled?'checked':''} readonly>
        <div class="toggle-track"></div><div class="toggle-thumb"></div>
      </label>
    </div>
    <div class="product-card-meta">
      ${badgePM(p.payment_method)}
      ${badgeSandbox(p.sandbox)}
      <span class="badge badge-sand">poll #${p.poll_order}</span>
      <span class="badge badge-sand">w:${p.weight}</span>
    </div>
    <div class="product-card-stats">
      <div class="product-stat">
        <div class="product-stat-label">累计使用</div>
        <div class="product-stat-val" style="color:var(--brand)">${p.total_used??0}</div>
      </div>
      <div class="product-stat">
        <div class="product-stat-label">上次使用</div>
        <div class="product-stat-val" style="font-size:11px;color:var(--text2)">${fmtAgo(p.last_used_at)}</div>
      </div>
    </div>
    <div class="product-card-actions">
      <button class="btn-ghost" onclick='openEditProduct(${JSON.stringify(p).replace(/'/g,"&#39;")})'>✏ 编辑</button>
      <button class="btn-danger" onclick="delProduct(${p.id})">🗑 删除</button>
    </div>
  </div>`;
}

// 快速添加：只需产品ID
function openQuickAddProduct(){
  openModal('⚡ 快速添加 B站产品',`
    <div class="info-box">只需输入 <strong>B站产品 ID</strong>，系统自动配置默认参数加入轮询队列。如需精细配置请使用「完整添加」。</div>
    <div class="err" id="qaErr"></div>
    <div class="form-group" style="margin-bottom:12px">
      <label>B站产品 ID *</label>
      <input id="qaBPID" placeholder="例：123 或 wc_product_456" style="font-family:var(--mono)">
    </div>
    <div class="form-group" style="margin-bottom:12px">
      <label>支付方式</label>
      <select id="qaPM">
        <option value="stripe">💳 Stripe</option>
        <option value="paypal">🅿 PayPal</option>
      </select>
    </div>
    <div class="form-group" style="margin-bottom:12px">
      <label>轮询顺序（越小越优先，0=自动排在末尾）</label>
      <input id="qaOrder" type="number" value="0" min="0">
    </div>
    <div class="info-box" style="font-size:11px;margin-bottom:0">
      💡 <strong>未执行过优先</strong>：系统默认使用 <span class="badge badge-sand" style="font-size:10px">round_robin</span> 策略，自动优先选择从未被使用（last_used_at 为空）的产品，实现公平轮询。
    </div>
    <div class="modal-actions">
      <button class="btn-ghost" onclick="closeModal()">取消</button>
      <button class="btn-primary" onclick="submitQuickAddProduct()">加入轮询</button>
    </div>
  `);
}

async function submitQuickAddProduct(){
  const err=document.getElementById('qaErr');
  err.style.display='none';
  const bpid=document.getElementById('qaBPID').value.trim();
  if(!bpid){err.textContent='请输入 B站产品 ID';err.style.display='block';return;}
  try{
    await POST('/user/products',{
      label:bpid,
      b_product_id:bpid,
      payment_method:document.getElementById('qaPM').value,
      sandbox:false,
      weight:10,
      poll_order:+document.getElementById('qaOrder').value||0,
    });
    closeModal();showToast('产品已加入轮询');navigate('products');
  }catch(e){err.textContent='❌ '+e.message;err.style.display='block';}
}

// 完整添加
function openAddProduct(){
  openModal('添加 B站产品',`
    <div class="err" id="apErr"></div>
    <div class="form-grid">
      <div class="form-group"><label>产品备注名称</label><input id="apLabel" placeholder="例：主力 Stripe 通道（留空则用ID）"></div>
      <div class="form-group"><label>B站产品 ID *</label><input id="apBPID" placeholder="B站 WooCommerce 产品ID" style="font-family:var(--mono)"></div>
    </div>
    <div class="form-grid">
      <div class="form-group">
        <label>支付方式 *</label>
        <select id="apPM">
          <option value="stripe">💳 Stripe</option>
          <option value="paypal">🅿 PayPal</option>
        </select>
      </div>
      <div class="form-group">
        <label>模式</label>
        <select id="apMode">
          <option value="false">🟢 正式 (生产)</option>
          <option value="true">🟡 沙盒 (测试)</option>
        </select>
      </div>
    </div>
    <div class="form-grid">
      <div class="form-group"><label>权重 (加权随机策略用, 1-100)</label><input id="apWeight" type="number" value="10" min="1" max="100"></div>
      <div class="form-group"><label>轮询排序号 (越小越优先)</label><input id="apOrder" type="number" value="0" min="0"></div>
    </div>
    <div class="modal-actions">
      <button class="btn-ghost" onclick="closeModal()">取消</button>
      <button class="btn-primary" onclick="submitAddProduct()">确认添加</button>
    </div>
  `);
}

async function submitAddProduct(){
  const err=document.getElementById('apErr');
  err.style.display='none';
  const bpid=document.getElementById('apBPID').value.trim();
  if(!bpid){err.textContent='B站产品ID为必填';err.style.display='block';return;}
  try{
    await POST('/user/products',{
      label:document.getElementById('apLabel').value.trim()||bpid,
      b_product_id:bpid,
      payment_method:document.getElementById('apPM').value,
      sandbox:document.getElementById('apMode').value==='true',
      weight:+document.getElementById('apWeight').value||10,
      poll_order:+document.getElementById('apOrder').value||0,
    });
    closeModal();showToast('产品已添加');navigate('products');
  }catch(e){err.textContent='❌ '+e.message;err.style.display='block';}
}

function openEditProduct(p){
  if(typeof p==='string') p=JSON.parse(p);
  openModal('编辑产品 — '+html(p.label||p.b_product_id),`
    <div class="err" id="epErr"></div>
    <div class="form-grid">
      <div class="form-group"><label>备注名称</label><input id="epLabel" value="${html(p.label||'')}"></div>
      <div class="form-group"><label>B站产品 ID</label><input id="epBPID" value="${html(p.b_product_id||'')}" style="font-family:var(--mono)"></div>
    </div>
    <div class="form-grid">
      <div class="form-group"><label>支付方式</label>
        <select id="epPM">
          <option value="stripe" ${p.payment_method==='stripe'?'selected':''}>💳 Stripe</option>
          <option value="paypal" ${p.payment_method==='paypal'?'selected':''}>🅿 PayPal</option>
        </select>
      </div>
      <div class="form-group"><label>模式</label>
        <select id="epMode">
          <option value="false" ${!p.sandbox?'selected':''}>🟢 正式 (生产)</option>
          <option value="true"  ${p.sandbox?'selected':''}>🟡 沙盒 (测试)</option>
        </select>
      </div>
    </div>
    <div class="form-grid">
      <div class="form-group"><label>权重 (1-100)</label><input id="epWeight" type="number" value="${p.weight||1}" min="1" max="100"></div>
      <div class="form-group"><label>轮询排序号</label><input id="epOrder" type="number" value="${p.poll_order||0}" min="0"></div>
    </div>
    <div class="modal-actions">
      <button class="btn-ghost" onclick="closeModal()">取消</button>
      <button class="btn-primary" onclick="submitEditProduct(${p.id})">保存修改</button>
    </div>
  `);
}

async function submitEditProduct(id){
  const err=document.getElementById('epErr');err.style.display='none';
  try{
    await PUT('/user/products/'+id,{
      label:document.getElementById('epLabel').value.trim(),
      b_product_id:document.getElementById('epBPID').value.trim(),
      payment_method:document.getElementById('epPM').value,
      sandbox:document.getElementById('epMode').value==='true',
      weight:+document.getElementById('epWeight').value||1,
      poll_order:+document.getElementById('epOrder').value||0,
    });
    closeModal();showToast('产品已更新');navigate('products');
  }catch(e){err.textContent='❌ '+e.message;err.style.display='block';}
}

async function toggleProduct(id,enabled){
  try{ await POST('/user/products/'+id+'/toggle',{}); showToast(enabled?'已禁用':'已启用'); navigate('products'); }
  catch(e){showToast('操作失败: '+e.message,true);}
}

async function delProduct(id){
  if(!confirm('确认删除该产品？')) return;
  try{ await DEL('/user/products/'+id); showToast('已删除'); navigate('products'); }
  catch(e){showToast('删除失败: '+e.message,true);}
}

/* ══════════════════════════════════════════
   Page: Stripe 账号管理
══════════════════════════════════════════ */
async function pageStripe(){
  const data=await GET('/user/stripe');
  const items=data?.items||[];
  setContent(`
    <div class="page-header flex-between">
      <div>
        <h2><span class="highlight-stripe">💳 Stripe</span> 账号管理</h2>
        <p>管理用于处理 Stripe 支付的账号配置，支持多账号智能分流</p>
      </div>
      <button class="btn-stripe" onclick="openAddStripe()">＋ 添加 Stripe 账号</button>
    </div>
    ${items.length===0?`<div class="card">${empty('💳','暂无 Stripe 账号，点击右上角添加')}</div>`:''}
    <div class="account-grid">${items.map(renderStripeCard).join('')}</div>
  `);
}

function renderStripeCard(s){
  const fw=s.final_weight??s.weight??0;
  const sw=s.smart_weight??0;
  const maxW=100;
  return `
  <div class="account-card stripe-card ${s.enabled?'':'disabled'}">
    <div class="account-card-header">
      <div>
        <div class="account-card-label">${html(s.label||'Stripe 账号 #'+s.id)}</div>
        <div class="account-card-sub">${html(s.key_preview||'sk_***')}</div>
      </div>
      <label class="toggle" onclick="toggleStripe(${s.id},${s.enabled})">
        <input type="checkbox" ${s.enabled?'checked':''} readonly>
        <div class="toggle-track"></div><div class="toggle-thumb"></div>
      </label>
    </div>
    <div class="account-card-stats">
      <div class="account-stat">
        <div class="account-stat-label">今日订单</div>
        <div class="account-stat-val" style="color:var(--stripe)">${s.daily_count??0}</div>
      </div>
      <div class="account-stat">
        <div class="account-stat-label">成功率</div>
        <div class="account-stat-val" style="color:var(--green)">${s.success_rate!=null?(+s.success_rate).toFixed(0)+'%':'—'}</div>
      </div>
      <div class="account-stat">
        <div class="account-stat-label">静态权重</div>
        <div class="account-stat-val" style="color:var(--amber)">${s.weight??10}</div>
      </div>
    </div>
    <div class="weight-bar-wrap">
      <div class="weight-bar-label">
        <span>综合权重 <span class="badge badge-stripe" style="font-size:9.5px">final: ${fw}</span></span>
        <span style="font-size:10px;color:var(--text3)">智能: ${sw}</span>
      </div>
      <div class="weight-bar"><div class="weight-bar-fill stripe-fill" style="width:${Math.min(fw/maxW*100,100)}%"></div></div>
    </div>
    <div class="flex-gap" style="margin-top:4px">
      ${s.sandbox?'<span class="badge badge-amber">沙盒</span>':'<span class="badge badge-green">生产</span>'}
      ${s.daily_limit?`<span class="badge badge-sand">日限 $${s.daily_limit}</span>`:''}
    </div>
    <div class="account-card-actions">
      <button class="btn-ghost" onclick='openEditStripe(${JSON.stringify(s).replace(/'/g,"&#39;")})'>✏ 编辑</button>
      <button class="btn-ghost" onclick="resetStripeDailyLimit(${s.id})">↺ 重置日限</button>
      <button class="btn-danger" onclick="delStripe(${s.id})">🗑</button>
    </div>
  </div>`;
}

function openAddStripe(){
  openModal('添加 Stripe 账号',`
    <div class="err" id="asErr"></div>
    <div class="form-group" style="margin-bottom:12px"><label>备注名称</label><input id="asLabel" placeholder="例：主力 Stripe US"></div>
    <div class="form-group" style="margin-bottom:12px">
      <label>Stripe Secret Key *</label>
      <input id="asKey" type="password" placeholder="sk_live_... 或 sk_test_..." style="font-family:var(--mono)">
    </div>
    <div class="form-group" style="margin-bottom:12px">
      <label>Webhook Secret（可选）</label>
      <input id="asWebhook" type="password" placeholder="whsec_...">
    </div>
    <div class="form-grid">
      <div class="form-group"><label>静态权重 (1-100)</label><input id="asWeight" type="number" value="10" min="1" max="100"></div>
      <div class="form-group"><label>日限额 USD（0=不限）</label><input id="asLimit" type="number" value="0" min="0"></div>
    </div>
    <div class="form-group" style="margin-bottom:12px">
      <label>模式</label>
      <select id="asMode">
        <option value="false">🟢 正式 (生产)</option>
        <option value="true">🟡 沙盒 (测试)</option>
      </select>
    </div>
    <div class="modal-actions">
      <button class="btn-ghost" onclick="closeModal()">取消</button>
      <button class="btn-stripe" onclick="submitAddStripe()">添加账号</button>
    </div>
  `);
}

async function submitAddStripe(){
  const err=document.getElementById('asErr');err.style.display='none';
  const key=document.getElementById('asKey').value.trim();
  if(!key){err.textContent='Stripe Secret Key 为必填';err.style.display='block';return;}
  try{
    await POST('/user/stripe',{
      label:document.getElementById('asLabel').value.trim()||null,
      secret_key:key,
      webhook_secret:document.getElementById('asWebhook').value.trim()||null,
      weight:+document.getElementById('asWeight').value||10,
      daily_limit:+document.getElementById('asLimit').value||0,
      sandbox:document.getElementById('asMode').value==='true',
    });
    closeModal();showToast('Stripe 账号已添加');navigate('stripe');
  }catch(e){err.textContent='❌ '+e.message;err.style.display='block';}
}

function openEditStripe(s){
  if(typeof s==='string') s=JSON.parse(s);
  openModal('编辑 Stripe 账号 — '+html(s.label||'#'+s.id),`
    <div class="err" id="esErr"></div>
    <div class="form-group" style="margin-bottom:12px"><label>备注名称</label><input id="esLabel" value="${html(s.label||'')}"></div>
    <div class="form-group" style="margin-bottom:12px">
      <label>新 Secret Key（留空不修改）</label>
      <input id="esKey" type="password" placeholder="sk_live_...">
    </div>
    <div class="form-grid">
      <div class="form-group"><label>静态权重 (1-100)</label><input id="esWeight" type="number" value="${s.weight||10}" min="1" max="100"></div>
      <div class="form-group"><label>日限额 USD（0=不限）</label><input id="esLimit" type="number" value="${s.daily_limit||0}" min="0"></div>
    </div>
    <div class="form-group" style="margin-bottom:12px;flex-direction:row;align-items:center;gap:10px">
      <label>启用</label><input id="esEnabled" type="checkbox" ${s.enabled?'checked':''}>
    </div>
    <div class="modal-actions">
      <button class="btn-ghost" onclick="closeModal()">取消</button>
      <button class="btn-stripe" onclick="submitEditStripe(${s.id})">保存</button>
    </div>
  `);
}

async function submitEditStripe(id){
  const err=document.getElementById('esErr');err.style.display='none';
  const body={
    label:document.getElementById('esLabel').value.trim()||null,
    weight:+document.getElementById('esWeight').value||10,
    daily_limit:+document.getElementById('esLimit').value||0,
    enabled:document.getElementById('esEnabled').checked,
  };
  const key=document.getElementById('esKey').value.trim();
  if(key) body.secret_key=key;
  try{
    await PUT('/user/stripe/'+id,body);
    closeModal();showToast('账号已更新');navigate('stripe');
  }catch(e){err.textContent='❌ '+e.message;err.style.display='block';}
}

async function toggleStripe(id,enabled){
  try{ await POST('/user/stripe/'+id+'/state',{enabled:!enabled}); showToast(enabled?'已禁用':'已启用'); navigate('stripe'); }
  catch(e){showToast('操作失败: '+e.message,true);}
}

async function resetStripeDailyLimit(id){
  if(!confirm('确认重置该账号今日限额计数？')) return;
  try{ await POST('/user/stripe/'+id+'/reset-daily',{}); showToast('日限额已重置'); navigate('stripe'); }
  catch(e){showToast('操作失败: '+e.message,true);}
}

async function delStripe(id){
  if(!confirm('确认删除该 Stripe 账号？')) return;
  try{ await DEL('/user/stripe/'+id); showToast('已删除'); navigate('stripe'); }
  catch(e){showToast('删除失败: '+e.message,true);}
}

/* ══════════════════════════════════════════
   Page: PayPal 账号管理
══════════════════════════════════════════ */
async function pagePaypal(){
  const data=await GET('/user/paypal');
  const items=data?.items||[];
  setContent(`
    <div class="page-header flex-between">
      <div>
        <h2><span class="highlight-paypal">🅿 PayPal</span> 账号管理</h2>
        <p>管理用于处理 PayPal 支付的账号配置，支持多账号智能分流</p>
      </div>
      <button class="btn-paypal" onclick="openAddPaypal()">＋ 添加 PayPal 账号</button>
    </div>
    ${items.length===0?`<div class="card">${empty('🅿','暂无 PayPal 账号，点击右上角添加')}</div>`:''}
    <div class="account-grid">${items.map(renderPaypalCard).join('')}</div>
  `);
}

function renderPaypalCard(p){
  const fw=p.final_weight??p.weight??0;
  const sw=p.smart_weight??0;
  return `
  <div class="account-card paypal-card ${p.enabled?'':'disabled'}">
    <div class="account-card-header">
      <div>
        <div class="account-card-label">${html(p.label||'PayPal 账号 #'+p.id)}</div>
        <div class="account-card-sub">${html(p.client_id_preview||p.email||'client_***')}</div>
      </div>
      <label class="toggle" onclick="togglePaypal(${p.id},${p.enabled})">
        <input type="checkbox" ${p.enabled?'checked':''} readonly>
        <div class="toggle-track"></div><div class="toggle-thumb"></div>
      </label>
    </div>
    <div class="account-card-stats">
      <div class="account-stat">
        <div class="account-stat-label">今日订单</div>
        <div class="account-stat-val" style="color:var(--paypal)">${p.daily_count??0}</div>
      </div>
      <div class="account-stat">
        <div class="account-stat-label">成功率</div>
        <div class="account-stat-val" style="color:var(--green)">${p.success_rate!=null?(+p.success_rate).toFixed(0)+'%':'—'}</div>
      </div>
      <div class="account-stat">
        <div class="account-stat-label">静态权重</div>
        <div class="account-stat-val" style="color:var(--amber)">${p.weight??10}</div>
      </div>
    </div>
    <div class="weight-bar-wrap">
      <div class="weight-bar-label">
        <span>综合权重 <span class="badge badge-paypal" style="font-size:9.5px">final: ${fw}</span></span>
        <span style="font-size:10px;color:var(--text3)">智能: ${sw}</span>
      </div>
      <div class="weight-bar"><div class="weight-bar-fill paypal-fill" style="width:${Math.min(fw/100*100,100)}%"></div></div>
    </div>
    <div class="flex-gap" style="margin-top:4px">
      ${p.sandbox?'<span class="badge badge-amber">沙盒</span>':'<span class="badge badge-green">生产</span>'}
      ${p.daily_limit?`<span class="badge badge-sand">日限 $${p.daily_limit}</span>`:''}
    </div>
    <div class="account-card-actions">
      <button class="btn-ghost" onclick='openEditPaypal(${JSON.stringify(p).replace(/'/g,"&#39;")})'>✏ 编辑</button>
      <button class="btn-ghost" onclick="resetPaypalDailyLimit(${p.id})">↺ 重置日限</button>
      <button class="btn-danger" onclick="delPaypal(${p.id})">🗑</button>
    </div>
  </div>`;
}

function openAddPaypal(){
  openModal('添加 PayPal 账号',`
    <div class="err" id="appErr"></div>
    <div class="form-group" style="margin-bottom:12px"><label>备注名称</label><input id="appLabel" placeholder="例：PayPal 主账号"></div>
    <div class="form-group" style="margin-bottom:12px">
      <label>Client ID *</label>
      <input id="appCID" placeholder="AxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxQ" style="font-family:var(--mono)">
    </div>
    <div class="form-group" style="margin-bottom:12px">
      <label>Client Secret *</label>
      <input id="appSec" type="password" placeholder="ExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxU" style="font-family:var(--mono)">
    </div>
    <div class="form-grid">
      <div class="form-group"><label>静态权重 (1-100)</label><input id="appWeight" type="number" value="10" min="1" max="100"></div>
      <div class="form-group"><label>日限额 USD（0=不限）</label><input id="appLimit" type="number" value="0" min="0"></div>
    </div>
    <div class="form-group" style="margin-bottom:12px">
      <label>模式</label>
      <select id="appMode">
        <option value="false">🟢 正式 (生产)</option>
        <option value="true">🟡 沙盒 (测试)</option>
      </select>
    </div>
    <div class="modal-actions">
      <button class="btn-ghost" onclick="closeModal()">取消</button>
      <button class="btn-paypal" onclick="submitAddPaypal()">添加账号</button>
    </div>
  `);
}

async function submitAddPaypal(){
  const err=document.getElementById('appErr');err.style.display='none';
  const cid=document.getElementById('appCID').value.trim();
  const sec=document.getElementById('appSec').value.trim();
  if(!cid||!sec){err.textContent='Client ID 和 Secret 为必填';err.style.display='block';return;}
  try{
    await POST('/user/paypal',{
      label:document.getElementById('appLabel').value.trim()||null,
      client_id:cid,
      client_secret:sec,
      weight:+document.getElementById('appWeight').value||10,
      daily_limit:+document.getElementById('appLimit').value||0,
      sandbox:document.getElementById('appMode').value==='true',
    });
    closeModal();showToast('PayPal 账号已添加');navigate('paypal');
  }catch(e){err.textContent='❌ '+e.message;err.style.display='block';}
}

function openEditPaypal(p){
  if(typeof p==='string') p=JSON.parse(p);
  openModal('编辑 PayPal 账号 — '+html(p.label||'#'+p.id),`
    <div class="err" id="epppErr"></div>
    <div class="form-group" style="margin-bottom:12px"><label>备注名称</label><input id="epppLabel" value="${html(p.label||'')}"></div>
    <div class="form-group" style="margin-bottom:12px"><label>新 Client Secret（留空不修改）</label><input id="epppSec" type="password" placeholder="留空不修改"></div>
    <div class="form-grid">
      <div class="form-group"><label>静态权重 (1-100)</label><input id="epppWeight" type="number" value="${p.weight||10}" min="1" max="100"></div>
      <div class="form-group"><label>日限额 USD（0=不限）</label><input id="epppLimit" type="number" value="${p.daily_limit||0}" min="0"></div>
    </div>
    <div class="form-group" style="margin-bottom:12px;flex-direction:row;align-items:center;gap:10px">
      <label>启用</label><input id="epppEnabled" type="checkbox" ${p.enabled?'checked':''}>
    </div>
    <div class="modal-actions">
      <button class="btn-ghost" onclick="closeModal()">取消</button>
      <button class="btn-paypal" onclick="submitEditPaypal(${p.id})">保存</button>
    </div>
  `);
}

async function submitEditPaypal(id){
  const err=document.getElementById('epppErr');err.style.display='none';
  const body={
    label:document.getElementById('epppLabel').value.trim()||null,
    weight:+document.getElementById('epppWeight').value||10,
    daily_limit:+document.getElementById('epppLimit').value||0,
    enabled:document.getElementById('epppEnabled').checked,
  };
  const sec=document.getElementById('epppSec').value.trim();
  if(sec) body.client_secret=sec;
  try{
    await PUT('/user/paypal/'+id,body);
    closeModal();showToast('账号已更新');navigate('paypal');
  }catch(e){err.textContent='❌ '+e.message;err.style.display='block';}
}

async function togglePaypal(id,enabled){
  try{ await POST('/user/paypal/'+id+'/state',{enabled:!enabled}); showToast(enabled?'已禁用':'已启用'); navigate('paypal'); }
  catch(e){showToast('操作失败: '+e.message,true);}
}

async function resetPaypalDailyLimit(id){
  if(!confirm('确认重置该账号今日限额计数？')) return;
  try{ await POST('/user/paypal/'+id+'/reset-daily',{}); showToast('日限额已重置'); navigate('paypal'); }
  catch(e){showToast('操作失败: '+e.message,true);}
}

async function delPaypal(id){
  if(!confirm('确认删除该 PayPal 账号？')) return;
  try{ await DEL('/user/paypal/'+id); showToast('已删除'); navigate('paypal'); }
  catch(e){showToast('删除失败: '+e.message,true);}
}

/* ══════════════════════════════════════════
   Page: 多渠道负载均衡
══════════════════════════════════════════ */
async function pageMultiChannel(){
  let stripeItems=[], paypalItems=[];
  try{ const s=await GET('/user/stripe'); stripeItems=s?.items||[]; }catch(e){}
  try{ const p=await GET('/user/paypal'); paypalItems=p?.items||[]; }catch(e){}

  const allAccounts=[
    ...stripeItems.map(x=>({...x,pm:'stripe'})),
    ...paypalItems.map(x=>({...x,pm:'paypal'})),
  ];
  const total=allAccounts.reduce((s,x)=>s+(x.final_weight??x.weight??0),0);

  setContent(`
    <div class="page-header">
      <h2>多渠道负载均衡</h2>
      <p>查看所有支付账号的权重分配与流量分配比例，综合权重 = 静态权重 × 0.4 + 智能权重 × 0.6</p>
    </div>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-label">Stripe 账号</div>
        <div class="stat-val" style="color:var(--stripe)">${stripeItems.length}</div>
        <div class="stat-sub">已配置</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">PayPal 账号</div>
        <div class="stat-val" style="color:var(--paypal)">${paypalItems.length}</div>
        <div class="stat-sub">已配置</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">活跃账号</div>
        <div class="stat-val" style="color:var(--green)">${allAccounts.filter(x=>x.enabled).length}</div>
        <div class="stat-sub">/ ${allAccounts.length} 总计</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">总权重</div>
        <div class="stat-val" style="color:var(--amber)">${total}</div>
        <div class="stat-sub">所有账号综合</div>
      </div>
    </div>

    <!-- 流量分配可视化 -->
    <div class="card" style="margin-bottom:14px">
      <div class="card-title">流量分配比例</div>
      <div style="display:flex;gap:0;height:28px;border-radius:8px;overflow:hidden;margin-bottom:12px">
        ${allAccounts.filter(x=>x.enabled).map(x=>{
          const fw=x.final_weight??x.weight??0;
          const pct=total>0?(fw/total*100).toFixed(1):0;
          const color=x.pm==='stripe'?'var(--stripe)':'var(--paypal)';
          return `<div style="flex:${fw};background:${color};opacity:0.8;position:relative;min-width:2px" title="${x.label||x.pm+' #'+x.id}: ${pct}%"></div>`;
        }).join('')}
        ${total===0?'<div style="flex:1;background:var(--border);opacity:0.5"></div>':''}
      </div>
      <div style="display:flex;flex-wrap:wrap;gap:8px">
        ${allAccounts.filter(x=>x.enabled).map(x=>{
          const fw=x.final_weight??x.weight??0;
          const pct=total>0?(fw/total*100).toFixed(1):0;
          const color=x.pm==='stripe'?'badge-stripe':'badge-paypal';
          return `<span class="badge ${color}">${html(x.label||x.pm+' #'+x.id)} ${pct}%</span>`;
        }).join('')}
      </div>
    </div>

    <!-- Stripe 账号权重表 -->
    <div class="card" style="margin-bottom:14px">
      <div class="card-title">
        💳 Stripe 账号权重
        <button class="btn-ghost" style="font-size:11px" onclick="navigate('stripe')">管理账号 →</button>
      </div>
      ${stripeItems.length===0?empty('💳','暂无 Stripe 账号'):renderWeightTable(stripeItems,'stripe')}
    </div>

    <!-- PayPal 账号权重表 -->
    <div class="card">
      <div class="card-title">
        🅿 PayPal 账号权重
        <button class="btn-ghost" style="font-size:11px" onclick="navigate('paypal')">管理账号 →</button>
      </div>
      ${paypalItems.length===0?empty('🅿','暂无 PayPal 账号'):renderWeightTable(paypalItems,'paypal')}
    </div>
  `);
}

function renderWeightTable(items, pm){
  const maxFW=Math.max(...items.map(x=>x.final_weight??x.weight??0),1);
  return `
  <div class="tbl-wrap"><table>
    <thead><tr><th>账号</th><th>静态权重</th><th>智能权重</th><th>综合权重</th><th>流量占比</th><th>成功率</th><th>今日订单</th><th>状态</th></tr></thead>
    <tbody>
    ${items.map(x=>{
      const sw=x.smart_weight??0;
      const fw=x.final_weight??x.weight??0;
      const totalFW=items.filter(i=>i.enabled).reduce((s,i)=>s+(i.final_weight??i.weight??0),0);
      const pct=totalFW>0?(fw/totalFW*100).toFixed(1)+'%':'—';
      const barW=Math.round(fw/maxFW*100);
      const barColor=pm==='stripe'?'var(--stripe)':'var(--paypal)';
      return `<tr>
        <td>
          <div style="font-weight:600;font-size:13px">${html(x.label||'账号 #'+x.id)}</div>
          <div class="mono" style="font-size:10px">${html(x.key_preview||x.client_id_preview||'')}</div>
        </td>
        <td class="mono">${x.weight??10}</td>
        <td class="mono">${sw}</td>
        <td>
          <div style="display:flex;align-items:center;gap:7px">
            <div style="flex:1;height:5px;background:var(--border);border-radius:3px;overflow:hidden;min-width:50px">
              <div style="width:${barW}%;height:100%;background:${barColor};border-radius:3px"></div>
            </div>
            <span class="mono" style="font-size:11px">${fw}</span>
          </div>
        </td>
        <td><span class="badge ${pm==='stripe'?'badge-stripe':'badge-paypal'}">${pct}</span></td>
        <td class="mono">${x.success_rate!=null?(+x.success_rate).toFixed(1)+'%':'—'}</td>
        <td class="mono">${x.daily_count??0}</td>
        <td>${x.enabled?'<span class="badge badge-green">启用</span>':'<span class="badge badge-red">禁用</span>'}</td>
      </tr>`;
    }).join('')}
    </tbody>
  </table></div>`;
}

/* ══════════════════════════════════════════
   Page: 轮询策略配置
══════════════════════════════════════════ */
async function pageStrategy(){
  const data=await GET('/user/strategy');
  const cur=data?.strategy||'round_robin';
  const products=data?.products||[];
  setContent(`
    <div class="page-header"><h2>轮询策略配置</h2><p>控制 B站产品的流量分配方式，当前策略：<strong style="color:var(--brand)">${cur}</strong></p></div>
    <div class="card">
      <div class="card-title">选择策略</div>
      <div class="strategy-grid">
        <div class="strategy-card ${cur==='round_robin'?'active':''}" onclick="setStrategy('round_robin')">
          <div class="strategy-icon">🔄</div>
          <h4>Round Robin 轮询</h4>
          <p>优先选择 <strong style="color:var(--brand)">从未使用</strong> 或 <strong style="color:var(--brand)">最久未使用</strong> 的产品，确保流量均匀分配。</p>
        </div>
        <div class="strategy-card ${cur==='random'?'active':''}" onclick="setStrategy('random')">
          <div class="strategy-icon">🎲</div>
          <h4>Weighted Random 加权随机</h4>
          <p>按 weight 权重概率随机选取通道，weight=60 的产品被选中概率约 60%，适合主力+备用分级。</p>
        </div>
        <div class="strategy-card ${cur==='fixed'?'active':''}" onclick="setStrategy('fixed')">
          <div class="strategy-icon">📌</div>
          <h4>Fixed 固定</h4>
          <p>始终选 poll_order 最小的产品，手动禁用后才切换到下一个，适合单一主力通道。</p>
        </div>
      </div>
      <div class="info-box" style="margin-bottom:0">
        💡 <strong>Round Robin 未执行优先</strong>：在轮询模式下，系统会优先选择 <code style="font-family:var(--mono);background:rgba(255,255,255,.05);padding:1px 5px;border-radius:4px">last_used_at = NULL</code> 的产品（即从未被调用过的产品），其次才按时间排序选取最久未使用的产品。
      </div>
    </div>
    <div class="card">
      <div class="card-title">通道状态一览</div>
      ${products.length===0?empty('📦','暂无产品，请先在「B站产品管理」页添加'):`
      <div class="tbl-wrap"><table>
        <thead><tr><th>排序</th><th>产品ID</th><th>支付方式</th><th>模式</th><th>权重</th><th>累计使用</th><th>上次使用</th><th>状态</th></tr></thead>
        <tbody>
          ${products.map(p=>`
          <tr>
            <td class="mono">#${p.poll_order}</td>
            <td>
              <strong>${html(p.label||'—')}</strong>
              <div class="mono" style="font-size:10px">${html(p.b_product_id)}</div>
            </td>
            <td>${badgePM(p.payment_method)}</td>
            <td>${badgeSandbox(p.sandbox)}</td>
            <td><span class="badge badge-blue">w:${p.weight}</span></td>
            <td class="mono">${p.total_used??0}</td>
            <td class="mono" style="font-size:10.5px">${fmtAgo(p.last_used_at)}</td>
            <td>${p.enabled?'<span class="badge badge-green">启用</span>':'<span class="badge badge-red">禁用</span>'}</td>
          </tr>`).join('')}
        </tbody>
      </table></div>`}
    </div>
  `);
}

async function setStrategy(s){
  try{ await PUT('/user/strategy',{strategy:s}); showToast('策略已更新为 '+s); navigate('strategy'); }
  catch(e){showToast('更新失败: '+e.message,true);}
}

/* ══════════════════════════════════════════
   Page: Webhooks
══════════════════════════════════════════ */
async function pageWebhooks(){
  const data=await GET('/user/webhooks');
  const items=data?.items||[];
  const aList=items.filter(x=>x.type==='a');
  const bList=items.filter(x=>x.type==='b');
  setContent(`
    <div class="page-header flex-between">
      <div><h2>A / B 站端点配置</h2><p>A站：接收 SS 的支付完成通知 &nbsp;|&nbsp; B站：SS 调用的实际支付站点</p></div>
      <div class="flex-gap">
        <button class="btn-ghost" onclick="openAddWebhook('a')">＋ A站端点</button>
        <button class="btn-primary" onclick="openAddWebhook('b')">＋ B站端点</button>
      </div>
    </div>
    <div class="card">
      <div class="card-title">A 站端点 <span style="font-size:11.5px;color:var(--text3);font-weight:400">（接收 SS→A 支付完成回调）</span></div>
      ${aList.length===0?empty('📡','暂无 A 站端点'):`
      <div class="tbl-wrap"><table>
        <thead><tr><th>ID</th><th>名称</th><th>地址</th><th>支付方式</th><th>API Key</th><th>状态</th><th>操作</th></tr></thead>
        <tbody>${aList.map(ep=>`
          <tr>
            <td class="mono">${ep.id}</td>
            <td>${html(ep.label||'—')}</td>
            <td class="mono" style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${html(ep.url)}</td>
            <td>${badgePM(ep.payment_method)}</td>
            <td class="mono" style="font-size:10px">${html(ep.a_api_key||'—')}</td>
            <td>${ep.enabled?'<span class="badge badge-green">启用</span>':'<span class="badge badge-red">禁用</span>'}</td>
            <td>
              <button class="btn-icon" title="配置串" onclick="getConfigString(${ep.id},'a')">📋</button>
              <button class="btn-icon" title="编辑" onclick="openEditWebhook(${ep.id})">✏</button>
              <button class="btn-icon" title="删除" onclick="delWebhook(${ep.id})">🗑</button>
            </td>
          </tr>`).join('')}
        </tbody>
      </table></div>`}
    </div>
    <div class="card">
      <div class="card-title">B 站端点 <span style="font-size:11.5px;color:var(--text3);font-weight:400">（SS 向 B 站发起建单请求）</span></div>
      ${bList.length===0?empty('🌐','暂无 B 站端点'):`
      <div class="tbl-wrap"><table>
        <thead><tr><th>ID</th><th>名称</th><th>地址</th><th>支付方式</th><th>B API Key</th><th>状态</th><th>操作</th></tr></thead>
        <tbody>${bList.map(ep=>`
          <tr>
            <td class="mono">${ep.id}</td>
            <td>${html(ep.label||'—')}</td>
            <td class="mono" style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${html(ep.url)}</td>
            <td>${badgePM(ep.payment_method)}</td>
            <td class="mono" style="font-size:10px">${html(ep.b_api_key||'—')}</td>
            <td>${ep.enabled?'<span class="badge badge-green">启用</span>':'<span class="badge badge-red">禁用</span>'}</td>
            <td>
              <button class="btn-icon" title="配置串" onclick="getConfigString(${ep.id},'b')">📋</button>
              <button class="btn-icon" title="编辑" onclick="openEditWebhook(${ep.id})">✏</button>
              <button class="btn-icon" title="删除" onclick="delWebhook(${ep.id})">🗑</button>
            </td>
          </tr>`).join('')}
        </tbody>
      </table></div>`}
    </div>
  `);
}

function openAddWebhook(type){
  const isA=type==='a';
  openModal(`添加 ${isA?'A站':'B站'} 端点`,`
    <div class="err" id="whErr"></div>
    <div class="info-box">${isA?'A站端点接收 SS 的支付完成通知，需填写 A站 Webhook URL。':'B站端点是 SS 实际调用的支付站点地址，需填写 B站 WooCommerce 根 URL。'}</div>
    <div class="form-grid">
      <div class="form-group"><label>备注名称</label><input id="whLabel" placeholder="例：主站端点"></div>
      <div class="form-group"><label>${isA?'A站 Webhook URL':'B站 WooCommerce URL'} *</label>
        <input id="whURL" placeholder="${isA?'https://yoursite.com/webhook/nme':'https://bstation.com'}">
      </div>
    </div>
    <div class="form-group" style="margin-bottom:12px">
      <label>适用支付方式</label>
      <select id="whPM">
        <option value="all">全部 (all)</option>
        <option value="stripe">💳 Stripe 专用</option>
        <option value="paypal">🅿 PayPal 专用</option>
      </select>
    </div>
    <div class="modal-actions">
      <button class="btn-ghost" onclick="closeModal()">取消</button>
      <button class="btn-primary" onclick="submitAddWebhook('${type}')">确认添加</button>
    </div>
  `);
}

async function submitAddWebhook(type){
  const err=document.getElementById('whErr');err.style.display='none';
  const url=document.getElementById('whURL').value.trim();
  if(!url){err.textContent='URL 为必填';err.style.display='block';return;}
  try{
    const res=await POST('/user/webhooks/'+type,{
      label:document.getElementById('whLabel').value.trim()||null,
      url,payment_method:document.getElementById('whPM').value,
    });
    closeModal();
    openModal('端点已创建 — 请保存配置串',`
      <p style="color:var(--text2);font-size:12.5px;margin-bottom:4px">🎉 创建成功！请立即复制配置串，密钥仅显示一次。</p>
      ${res.config_string?`
        <div class="config-string-box">${html(res.config_string)}
          <button class="key-copy" onclick="copyText('${res.config_string.replace(/'/g,"\\'")}')">复制</button>
        </div>
        <div class="config-hint">⚠ ${res.config_hint||'请将配置串粘贴到插件后台'}</div>
      `:''}
      ${res.callback_url?`<p style="margin-top:10px;font-size:11.5px;color:var(--text3)">回调地址: <span class="mono">${html(res.callback_url)}</span></p>`:''}
      <div class="modal-actions"><button class="btn-primary" onclick="closeModal();navigate('webhooks')">完成</button></div>
    `);
  }catch(e){err.textContent='❌ '+e.message;err.style.display='block';}
}

async function getConfigString(id,type){
  try{
    const res=await GET('/user/webhooks/'+id+'/config-string');
    openModal('配置串 — '+type.toUpperCase()+'站',`
      <div class="config-string-box">${html(res.config_string||'—')}
        <button class="key-copy" onclick="copyText('${(res.config_string||'').replace(/'/g,"\\'")}')">复制</button>
      </div>
      ${res.callback_url?`<p style="margin-top:10px;font-size:11.5px;color:var(--text3)">回调地址: <span class="mono">${html(res.callback_url)}</span></p>`:''}
      <div class="modal-actions"><button class="btn-ghost" onclick="closeModal()">关闭</button></div>
    `);
  }catch(e){showToast('获取失败: '+e.message,true);}
}

function openEditWebhook(id){
  openModal('编辑端点',`
    <div class="err" id="ewErr"></div>
    <div class="form-group" style="margin-bottom:12px"><label>新 URL（留空不修改）</label><input id="ewURL" placeholder="https://…"></div>
    <div class="form-group" style="margin-bottom:12px"><label>备注名称</label><input id="ewLabel"></div>
    <div class="form-group" style="margin-bottom:12px">
      <label>支付方式</label>
      <select id="ewPM"><option value="all">全部</option><option value="stripe">Stripe</option><option value="paypal">PayPal</option></select>
    </div>
    <div class="form-group" style="margin-bottom:12px;flex-direction:row;align-items:center;gap:10px">
      <label>启用</label><input id="ewEnabled" type="checkbox" checked>
    </div>
    <div class="modal-actions">
      <button class="btn-ghost" onclick="closeModal()">取消</button>
      <button class="btn-primary" onclick="submitEditWebhook(${id})">保存</button>
    </div>
  `);
}

async function submitEditWebhook(id){
  const err=document.getElementById('ewErr');err.style.display='none';
  const body={};
  const url=document.getElementById('ewURL').value.trim();
  const label=document.getElementById('ewLabel').value.trim();
  if(url) body.url=url;
  if(label) body.label=label;
  body.payment_method=document.getElementById('ewPM').value;
  body.enabled=document.getElementById('ewEnabled').checked;
  try{
    await PUT('/user/webhooks/'+id,body);
    closeModal();showToast('端点已更新');navigate('webhooks');
  }catch(e){err.textContent='❌ '+e.message;err.style.display='block';}
}

async function delWebhook(id){
  if(!confirm('确认删除该端点？')) return;
  try{ await DEL('/user/webhooks/'+id); showToast('已删除'); navigate('webhooks'); }
  catch(e){showToast('删除失败: '+e.message,true);}
}

