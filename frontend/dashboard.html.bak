}

/* ══════════════════════════════════════════
   Admin: 智能路由分析
══════════════════════════════════════════ */
async function pageAdminRouting(){
  let stats=[], metrics=[];
  try{ const s=await GET('/admin/smart-routing/stats'); stats=s?.accounts||s?.items||s||[]; }catch(e){}
  try{ const m=await GET('/admin/metrics/channels'); metrics=m?.items||m||[]; }catch(e){}

  setContent(`
    <div class="page-header flex-between">
      <div><h2>🧠 智能路由分析</h2><p>实时监控各支付账号的动态权重、成功率、响应时间与风控通过率</p></div>
      <button class="btn-primary" onclick="recalcRouting()">⟳ 立即重算权重</button>
    </div>

    <div class="info-box">
      <strong>权重计算公式：</strong>
      <code style="font-family:var(--mono);background:rgba(255,255,255,.05);padding:2px 8px;border-radius:4px;font-size:11.5px">
        final_weight = static_weight × 0.4 + smart_weight × 0.6
      </code>
      &nbsp;&nbsp;
      <code style="font-family:var(--mono);background:rgba(255,255,255,.05);padding:2px 8px;border-radius:4px;font-size:11.5px">
        smart_weight = success_rate × 0.5 + risk_pass_rate × 0.3 + (1 − norm_response) × 20
      </code>
    </div>

    <!-- 账号权重快照卡片 -->
    <div class="section-header"><h3>账号权重快照</h3><span style="font-size:11.5px;color:var(--text3)">基于过去 24 小时指标实时计算</span></div>
    ${stats.length===0?`<div class="card">${empty('🧠','暂无路由数据，请先添加支付账号')}</div>`:`
    <div class="routing-grid" id="routingGrid">${stats.map(renderRoutingCard).join('')}</div>`}

    <!-- 渠道原始指标 -->
    <div class="section-header" style="margin-top:20px"><h3>渠道原始指标</h3><span style="font-size:11.5px;color:var(--text3)">过去 24h 数据</span></div>
    <div class="card">
      ${metrics.length===0?empty('📊','暂无指标数据'):`
      <div class="tbl-wrap"><table>
        <thead><tr><th>账号</th><th>支付方式</th><th>成功率</th><th>风控通过率</th><th>平均响应(ms)</th><th>总请求</th><th>成功数</th><th>智能权重</th><th>更新时间</th></tr></thead>
        <tbody>${metrics.map(m=>`
          <tr>
            <td>
              <div style="font-weight:600">${html(m.label||'账号 #'+m.account_id)}</div>
              <div class="mono" style="font-size:10px">${html(m.account_type||'')}</div>
            </td>
            <td>${badgePM(m.payment_method||m.account_type)}</td>
            <td>
              <div style="display:flex;align-items:center;gap:6px">
                <div style="width:48px;height:4px;background:var(--border);border-radius:2px;overflow:hidden">
                  <div style="width:${Math.min(m.success_rate||0,100)}%;height:100%;background:var(--green);border-radius:2px"></div>
                </div>
                <span class="mono" style="color:var(--green)">${m.success_rate!=null?(+m.success_rate).toFixed(1)+'%':'—'}</span>
              </div>
            </td>
            <td>
              <div style="display:flex;align-items:center;gap:6px">
                <div style="width:48px;height:4px;background:var(--border);border-radius:2px;overflow:hidden">
                  <div style="width:${Math.min(m.risk_pass_rate||0,100)}%;height:100%;background:var(--brand);border-radius:2px"></div>
                </div>
                <span class="mono" style="color:var(--brand)">${m.risk_pass_rate!=null?(+m.risk_pass_rate).toFixed(1)+'%':'—'}</span>
              </div>
            </td>
            <td class="mono">${m.avg_response_ms!=null?Math.round(m.avg_response_ms)+'ms':'—'}</td>
            <td class="mono">${m.total_requests??'—'}</td>
            <td class="mono">${m.success_count??'—'}</td>
            <td>
              <span class="badge badge-purple">${m.smart_weight!=null?(+m.smart_weight).toFixed(1):'—'}</span>
            </td>
            <td class="mono" style="font-size:10.5px">${fmtDate(m.updated_at)}</td>
          </tr>`).join('')}
        </tbody>
      </table></div>`}
    </div>
  `);
}

function renderRoutingCard(a){
  const sw=a.smart_weight??0;
  const fw=a.final_weight??0;
  const sr=a.success_rate??0;
  const rpr=a.risk_pass_rate??0;
  const isStripe=(a.payment_method||a.type||'').includes('stripe');
  const accentColor=isStripe?'var(--stripe)':'var(--paypal)';
  const scorePct=Math.min(fw,100);
  const r=22;const circ=2*Math.PI*r;
  const dash=circ*(scorePct/100);
  const scoreColor=fw>=70?'var(--green)':fw>=40?'var(--amber)':'var(--red)';

  return `
  <div class="routing-card">
    <div class="routing-header">
      <div>
        <div style="font-weight:700;font-size:14px">${html(a.label||'账号 #'+(a.account_id||a.id))}</div>
        <div style="margin-top:3px">${isStripe?'<span class="badge badge-stripe">Stripe</span>':'<span class="badge badge-paypal">PayPal</span>'}</div>
      </div>
      <div class="score-ring">
        <svg width="52" height="52" viewBox="0 0 52 52">
          <circle cx="26" cy="26" r="${r}" fill="none" stroke="var(--border2)" stroke-width="4"/>
          <circle cx="26" cy="26" r="${r}" fill="none" stroke="${scoreColor}" stroke-width="4"
            stroke-dasharray="${dash.toFixed(1)} ${circ.toFixed(1)}" stroke-linecap="round"/>
        </svg>
        <div class="score-text" style="color:${scoreColor}">${fw}</div>
      </div>
    </div>
    <div class="metric-row">
      <span class="metric-label">静态权重</span>
      <span class="metric-val">${a.static_weight??a.weight??'—'}</span>
    </div>
    <div class="metric-row">
      <span class="metric-label">智能权重</span>
      <span class="metric-val" style="color:var(--purple)">${typeof sw==='number'?sw.toFixed(1):sw}</span>
    </div>
    <div class="metric-row">
      <span class="metric-label">成功率</span>
      <span class="metric-val" style="color:var(--green)">${typeof sr==='number'?sr.toFixed(1)+'%':sr}</span>
    </div>
    <div class="metric-row">
      <span class="metric-label">风控通过率</span>
      <span class="metric-val" style="color:var(--brand)">${typeof rpr==='number'?rpr.toFixed(1)+'%':rpr}</span>
    </div>
    <div class="metric-row">
      <span class="metric-label">响应时间</span>
      <span class="metric-val">${a.avg_response_ms!=null?Math.round(a.avg_response_ms)+'ms':'—'}</span>
    </div>
    <div class="metric-row">
      <span class="metric-label">今日请求</span>
      <span class="metric-val">${a.total_requests??'—'}</span>
    </div>
  </div>`;
}

async function recalcRouting(){
  try{
    await POST('/admin/smart-routing/recalculate',{});
    showToast('权重已重新计算');
    navigate('admin-routing');
  }catch(e){showToast('重算失败: '+e.message,true);}
}

/* ══════════════════════════════════════════
   Admin: 风控规则
══════════════════════════════════════════ */
async function pageAdminRisk(){
  const d=await GET('/admin/risk-rules');
  const items=d?.items||[];
  setContent(`
    <div class="page-header flex-between">
      <div><h2>风控规则</h2><p>控制订单金额拦截、IP 限速等风控策略</p></div>
      <button class="btn-primary" onclick="openAddRisk()">＋ 新增规则</button>
    </div>
    <div class="card">
      ${items.length===0?empty('🛡','暂无风控规则'):`
      <div class="tbl-wrap"><table>
        <thead><tr><th>ID</th><th>规则名称</th><th>配置</th><th>命中</th><th>状态</th><th>更新时间</th><th>操作</th></tr></thead>
        <tbody>${items.map(r=>`
          <tr>
            <td class="mono">${r.id}</td>
            <td><strong>${html(r.name)}</strong></td>
            <td class="mono" style="font-size:10.5px;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${html(r.config)}</td>
            <td><span class="badge badge-amber">${r.hit_count??0}</span></td>
            <td>${r.enabled?'<span class="badge badge-green">启用</span>':'<span class="badge badge-red">禁用</span>'}</td>
            <td class="mono" style="font-size:10.5px">${fmtDate(r.updated_at)}</td>
            <td>
              <button class="btn-ghost" onclick='openEditRisk(${JSON.stringify(r).replace(/'/g,"&#39;")})'>✏ 编辑</button>
              <button class="btn-danger" onclick="delRisk(${r.id})">删除</button>
            </td>
          </tr>`).join('')}
        </tbody>
      </table></div>`}
    </div>
  `);
}

function openAddRisk(){
  openModal('新增风控规则',`
    <div class="err" id="arErr"></div>
    <div class="form-group" style="margin-bottom:12px"><label>规则名称 *</label><input id="arName" placeholder="例: high_amount_block"></div>
    <div class="form-group" style="margin-bottom:12px"><label>配置 JSON *</label>
      <textarea id="arConfig" rows="4" style="font-family:var(--mono);font-size:11.5px" placeholder='{"action":"block","amount_gt":5000}'></textarea>
    </div>
    <div class="form-group" style="margin-bottom:12px;flex-direction:row;align-items:center;gap:10px">
      <label>启用</label><input id="arEnabled" type="checkbox" checked>
    </div>
    <div class="modal-actions">
      <button class="btn-ghost" onclick="closeModal()">取消</button>
      <button class="btn-primary" onclick="submitAddRisk()">创建</button>
    </div>
  `);
}

async function submitAddRisk(){
  const err=document.getElementById('arErr');err.style.display='none';
  const name=document.getElementById('arName').value.trim();
  const config=document.getElementById('arConfig').value.trim();
  if(!name||!config){err.textContent='规则名和配置为必填';err.style.display='block';return;}
  try{ JSON.parse(config); }catch(e){err.textContent='配置必须是合法 JSON';err.style.display='block';return;}
  try{
    await POST('/admin/risk-rules',{name,config,enabled:document.getElementById('arEnabled').checked});
    closeModal();showToast('风控规则已创建');navigate('admin-risk');
  }catch(e){err.textContent='❌ '+e.message;err.style.display='block';}
}

function openEditRisk(r){
  if(typeof r==='string') r=JSON.parse(r);
  openModal('编辑风控规则 — '+html(r.name),`
    <div class="err" id="erErr"></div>
    <div class="form-group" style="margin-bottom:12px"><label>配置 JSON</label>
      <textarea id="erConfig" rows="4" style="font-family:var(--mono);font-size:11.5px">${html(r.config||'{}')}</textarea>
    </div>
    <div class="form-group" style="margin-bottom:12px;flex-direction:row;align-items:center;gap:10px">
      <label>启用</label><input id="erEnabled" type="checkbox" ${r.enabled?'checked':''}>
    </div>
    <div class="modal-actions">
      <button class="btn-ghost" onclick="closeModal()">取消</button>
      <button class="btn-primary" onclick="submitEditRisk(${r.id})">保存</button>
    </div>
  `);
}

async function submitEditRisk(id){
  const err=document.getElementById('erErr');err.style.display='none';
  const config=document.getElementById('erConfig').value.trim();
  try{ JSON.parse(config); }catch(e){err.textContent='配置必须是合法 JSON';err.style.display='block';return;}
  try{
    await PUT('/admin/risk-rules/'+id,{config,enabled:document.getElementById('erEnabled').checked});
    closeModal();showToast('风控规则已更新');navigate('admin-risk');
  }catch(e){err.textContent='❌ '+e.message;err.style.display='block';}
}

async function delRisk(id){
  if(!confirm('确认删除该风控规则？')) return;
  try{ await DEL('/admin/risk-rules/'+id); showToast('已删除'); navigate('admin-risk'); }
  catch(e){showToast('删除失败: '+e.message,true);}
}

/* ══════════════════════════════════════════
   Admin: 告警、审计、报表
══════════════════════════════════════════ */
async function pageAdminAlerts(){
  const d=await GET('/admin/alerts');
  const items=d?.items||[];
  setContent(`
    <div class="page-header"><h2>告警中心</h2></div>
    <div class="card">
      ${items.length===0?empty('🚨','暂无告警记录'):`
      <div class="tbl-wrap"><table>
        <thead><tr><th>ID</th><th>级别</th><th>事件</th><th>状态</th><th>时间</th><th>操作</th></tr></thead>
        <tbody>${items.map(a=>`
          <tr>
            <td class="mono">${a.id}</td>
            <td><span class="badge ${a.level==='critical'?'badge-red':a.level==='warn'?'badge-amber':'badge-blue'}">${a.level}</span></td>
            <td>${html(a.event)}</td>
            <td>${a.status==='resolved'?'<span class="badge badge-green">已解决</span>':'<span class="badge badge-amber">待处理</span>'}</td>
            <td class="mono" style="font-size:10.5px">${fmtDate(a.created_at)}</td>
            <td>${a.status!=='resolved'?`<button class="btn-ghost" onclick="resolveAlert(${a.id})">✔ 标记解决</button>`:''}</td>
          </tr>`).join('')}
        </tbody>
      </table></div>`}
    </div>
  `);
}

async function resolveAlert(id){
  try{ await POST('/admin/alerts/'+id+'/resolve',{}); showToast('已标记为解决'); navigate('admin-alerts'); }
  catch(e){showToast('操作失败: '+e.message,true);}
}

/* ══════════════════════════════════════════
   Admin: 系统设置（移除 Stripe/PayPal 全局配置）
══════════════════════════════════════════ */
async function pageAdminSettings(){
  const d=await GET('/admin/settings');
  const items=d?.items||[];
  setContent(`
    <div class="page-header"><h2>系统设置</h2><p>全局系统参数配置</p></div>
    <div class="card">
      <div class="card-title">⚙ 全部配置项</div>
      <div class="info-box">Stripe / PayPal 账号配置已移至「支付通道」菜单下各自独立管理，不再在此统一配置。</div>
      ${items.length===0?empty('⚙','暂无配置项'):`
      <div class="tbl-wrap"><table>
        <thead><tr><th>Key</th><th>Value</th><th>更新时间</th></tr></thead>
        <tbody>${items.filter(s=>!s.key.includes('stripe')&&!s.key.includes('paypal')).map(s=>`
          <tr>
            <td class="mono">${html(s.key)}</td>
            <td class="mono" style="max-width:260px;overflow:hidden;text-overflow:ellipsis">${s.key.includes('secret')||s.key.includes('key')?'••••••••••':html(s.value||'')}</td>
            <td class="mono" style="font-size:10.5px">${fmtDate(s.updated_at)}</td>
          </tr>`).join('')}
        </tbody>
      </table></div>`}
    </div>
  `);
}

async function pageAdminAudit(){
  const d=await GET('/admin/audit-logs');
  const items=d?.items||[];
  setContent(`
    <div class="page-header"><h2>审计日志</h2></div>
    <div class="card">
      ${items.length===0?empty('📝','暂无审计日志'):`
      <div class="tbl-wrap"><table>
        <thead><tr><th>ID</th><th>操作者</th><th>方法</th><th>路径</th><th>IP</th><th>时间</th></tr></thead>
        <tbody>${items.map(l=>`
          <tr>
            <td class="mono">${l.id}</td>
            <td class="mono">${l.actor_id||'—'}</td>
            <td><span class="badge badge-blue">${l.method}</span></td>
            <td class="mono" style="font-size:10.5px">${html(l.path)}</td>
            <td class="mono">${html(l.ip||'—')}</td>
            <td class="mono" style="font-size:10.5px">${fmtDate(l.created_at)}</td>
          </tr>`).join('')}
        </tbody>
      </table></div>`}
    </div>
  `);
}

async function pageAdminReports(){
  const d=await GET('/admin/reports');
  setContent(`
    <div class="page-header"><h2>数据报表</h2></div>
    <div class="card"><pre class="json">${html(JSON.stringify(d,null,2))}</pre></div>
  `);
}

/* ══════════════════════════════════════════
   Pages Registry
══════════════════════════════════════════ */
const Pages={
  overview:       pageOverview,
  products:       pageProducts,
  stripe:         pageStripe,
  paypal:         pagePaypal,
  multichannel:   pageMultiChannel,
  strategy:       pageStrategy,
  webhooks:       pageWebhooks,
  orders:         pageOrders,
  apikeys:        pageAPIKeys,
  'admin-stats':    pageAdminStats,
  'admin-users':    pageAdminUsers,
  'admin-orders':   pageAdminOrders,
  'admin-routing':  pageAdminRouting,
  'admin-risk':     pageAdminRisk,
  'admin-alerts':   pageAdminAlerts,
  'admin-settings': pageAdminSettings,
  'admin-audit':    pageAdminAudit,
  'admin-reports':  pageAdminReports,
};

/* ══════════════════════════════════════════
   Init
══════════════════════════════════════════ */
function doLogout(){
  localStorage.removeItem('nme_token');
  localStorage.removeItem('nme_refresh_token');
  window.location.href='/login.html';
}

async function init(){
  if(!S.token){ window.location.href='/login.html'; return; }
  let me;
  try{ me=await GET('/auth/me'); }
  catch(e){ doLogout(); return; }
  S.user=me; S.role=me.role||''; S.perms=me.permissions||{};

  document.getElementById('topAvatar').textContent=(me.email||'?')[0].toUpperCase();
  document.getElementById('topName').textContent=me.email||'—';
  document.getElementById('topRole').textContent=roleLabel(S.role);
  document.getElementById('sidebarFoot').textContent='v9.0 · '+me.email;

  buildSidebar();
  await navigate('overview');
}

document.getElementById('btnLogout').onclick=doLogout;
document.getElementById('btnRefresh').onclick=()=>navigate(S.currentPage||'overview');
init();
</script>
</body>
</html>
