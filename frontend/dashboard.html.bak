/* ══════════════════════════════════════════
   Admin: 用户管理（只有 super_admin 和 user）
══════════════════════════════════════════ */
async function pageAdminUsers(){
  const d=await GET('/admin/users');
  const items=d?.items||[];
  setContent(`
    <div class="page-header flex-between">
      <div><h2>用户管理</h2><p>系统全部用户（共 ${items.length} 个）</p></div>
      <button class="btn-primary" onclick="openAddUser()">＋ 新增用户</button>
    </div>
    <div class="card">
      ${items.length===0?empty('👥','暂无用户'):`
      <div class="tbl-wrap"><table>
        <thead><tr><th>ID</th><th>邮箱</th><th>角色</th><th>负载策略</th><th>状态</th><th>创建时间</th><th>操作</th></tr></thead>
        <tbody>${items.map(u=>`
          <tr>
            <td class="mono">${u.id}</td>
            <td>${html(u.email)}</td>
            <td><span class="badge badge-blue">${roleLabel(u.role)}</span></td>
            <td><span class="badge badge-sand">${u.product_strategy||'round_robin'}</span></td>
            <td>${u.status==='active'?'<span class="badge badge-green">启用</span>':'<span class="badge badge-red">禁用</span>'}</td>
            <td class="mono" style="font-size:10.5px">${fmtDate(u.created_at)}</td>
            <td>
              <button class="btn-ghost" onclick='openEditUser(${JSON.stringify(u).replace(/'/g,"&#39;")})'>✏ 编辑</button>
              <button class="btn-danger" onclick="delUser(${u.id})">删除</button>
            </td>
          </tr>`).join('')}
        </tbody>
      </table></div>`}
    </div>
  `);
}

function openAddUser(){
  openModal('新增用户',`
    <div class="err" id="auErr"></div>
    <div class="form-grid">
      <div class="form-group"><label>邮箱 *</label><input id="auEmail" type="email" placeholder="user@example.com"></div>
      <div class="form-group"><label>密码 *</label><input id="auPass" type="password" placeholder="至少8位"></div>
    </div>
    <div class="form-grid">
      <div class="form-group"><label>角色</label>
        <select id="auRole">
          <option value="user">用户</option>
          <option value="super_admin">超级管理员</option>
        </select>
      </div>
      <div class="form-group"><label>过期时间（留空永不过期）</label><input id="auExpire" type="datetime-local"></div>
    </div>
    <div class="modal-actions">
      <button class="btn-ghost" onclick="closeModal()">取消</button>
      <button class="btn-primary" onclick="submitAddUser()">创建</button>
    </div>
  `);
}

async function submitAddUser(){
  const err=document.getElementById('auErr');err.style.display='none';
  const email=document.getElementById('auEmail').value.trim();
  const pass=document.getElementById('auPass').value;
  if(!email||!pass){err.textContent='邮箱和密码为必填';err.style.display='block';return;}
  try{
    const body={email,password:pass,role:document.getElementById('auRole').value};
    const exp=document.getElementById('auExpire').value;
    if(exp) body.expires_at=new Date(exp).toISOString();
    await POST('/admin/users',body);
    closeModal();showToast('用户已创建');navigate('admin-users');
  }catch(e){err.textContent='❌ '+e.message;err.style.display='block';}
}

function openEditUser(u){
  if(typeof u==='string') u=JSON.parse(u);
  openModal('编辑用户 — '+html(u.email),`
    <div class="err" id="euErr"></div>
    <div class="form-grid">
      <div class="form-group"><label>角色</label>
        <select id="euRole">
          <option value="user" ${u.role==='user'?'selected':''}>用户</option>
          <option value="super_admin" ${u.role==='super_admin'?'selected':''}>超级管理员</option>
        </select>
      </div>
      <div class="form-group"><label>状态</label>
        <select id="euStatus">
          <option value="active" ${u.status==='active'?'selected':''}>启用</option>
          <option value="inactive" ${u.status==='inactive'?'selected':''}>禁用</option>
        </select>
      </div>
    </div>
    <div class="form-group" style="margin-bottom:12px"><label>新密码（留空不修改）</label><input id="euPass" type="password" placeholder="留空不修改"></div>
    <div class="modal-actions">
      <button class="btn-ghost" onclick="closeModal()">取消</button>
      <button class="btn-primary" onclick="submitEditUser(${u.id})">保存</button>
    </div>
  `);
}

async function submitEditUser(id){
  const err=document.getElementById('euErr');err.style.display='none';
  const body={role:document.getElementById('euRole').value,status:document.getElementById('euStatus').value};
  const pass=document.getElementById('euPass').value;
  if(pass) body.password=pass;
  try{
    await PUT('/admin/users/'+id,body);
    closeModal();showToast('用户已更新');navigate('admin-users');
  }catch(e){err.textContent='❌ '+e.message;err.style.display='block';}
}

async function delUser(id){
  if(!confirm('确认删除该用户？此操作不可逆！')) return;
  try{ await DEL('/admin/users/'+id); showToast('已删除'); navigate('admin-users'); }
  catch(e){showToast('删除失败: '+e.message,true);}
}

