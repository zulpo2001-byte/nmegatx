   Page: API Keys
══════════════════════════════════════════ */
async function pageAPIKeys(){
  const data=await GET('/user/api-keys');
  const items=data?.items||[];
  setContent(`
    <div class="page-header flex-between">
      <div><h2>API Key 管理</h2><p>用于 A站插件调用 SS 网关接口的身份凭证</p></div>
      <button class="btn-primary" onclick="createAPIKey()">＋ 新建 Key</button>
    </div>
    <div class="card">
      ${items.length===0?empty('🔑','暂无 API Key'):`
      <div class="tbl-wrap"><table>
        <thead><tr><th>ID</th><th>API Key</th><th>状态</th><th>创建时间</th><th>操作</th></tr></thead>
        <tbody>${items.map(k=>`
          <tr>
            <td class="mono">${k.id}</td>
            <td>
              <div class="mono" style="font-size:11px">${html(k.api_key)}</div>
              <button class="btn-icon" style="margin-top:3px;font-size:10.5px" onclick="copyText('${k.api_key}')">复制</button>
            </td>
            <td>${k.enabled?'<span class="badge badge-green">启用</span>':'<span class="badge badge-red">禁用</span>'}</td>
            <td class="mono" style="font-size:10.5px">${fmtDate(k.created_at)}</td>
            <td><button class="btn-danger" onclick="delAPIKey(${k.id})">删除</button></td>
          </tr>`).join('')}
        </tbody>
      </table></div>`}
    </div>
  `);
}

async function createAPIKey(){
  try{
    const res=await POST('/user/api-keys',{});
    openModal('API Key 已创建',`
      <p style="color:var(--text2);font-size:12.5px;margin-bottom:12px">⚠ Secret 仅显示一次，请立即保存。</p>
      <div class="form-group"><label>API Key</label>
        <div class="key-box">${html(res.api_key)}<button class="key-copy" onclick="copyText('${res.api_key}')">复制</button></div>
      </div>
      <div class="form-group" style="margin-top:9px"><label>Secret</label>
        <div class="key-box" style="color:#f0abfc">${html(res.secret)}<button class="key-copy" onclick="copyText('${res.secret}')">复制</button></div>
      </div>
      <div class="modal-actions"><button class="btn-primary" onclick="closeModal();navigate('apikeys')">完成</button></div>
    `);
  }catch(e){showToast('创建失败: '+e.message,true);}
}

async function delAPIKey(id){
  if(!confirm('确认删除此 API Key？')) return;
  try{ await DEL('/user/api-keys/'+id); showToast('已删除'); navigate('apikeys'); }
  catch(e){showToast('删除失败: '+e.message,true);}
}

